config_version=5

[application]

config/name="MultiplayerSystem3D"
run/main_scene="uid://b4hbjmuoxr3od"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

NetworkManager="*uid://c0kxtgivn4uom"
Console="*uid://ouiu5xh1cs8n"
Leaderboard="*uid://cawn7r8wbbqbx"
NetworkTime="*uid://cnqdxyjptkfvp"
NetworkTimeSynchronizer="*uid://5rmn2ik3kjo8"
NetworkRollback="*uid://gas743comroj"
NetworkEvents="*uid://bdmobxxptryj0"
NetworkPerformance="*uid://cqgf7aqmjfoa3"

[display]

